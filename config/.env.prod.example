# Herkulio Production Environment Variables
# Copy this to .env.prod and fill in real values
# NEVER commit .env.prod to Git!

# Database (PostgreSQL in Docker)
DB_USER=herkulio
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD_32_CHARS_MIN
DB_NAME=herkulio
DATABASE_URL=postgresql://herkulio:CHANGE_ME@postgres:5432/herkulio

# Redis
REDIS_URL=redis://redis:6379/0

# Security (generate with: openssl rand -hex 32)
SECRET_KEY=CHANGE_ME_64_CHAR_HEX_STRING
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# OpenRouter (AI synthesis)
OPENROUTER_API_KEY=sk-or-v1-YOUR_OPENROUTER_KEY
DEFAULT_MODEL=google/gemini-2.5-flash

# Search APIs
TAVILY_API_KEY=tvly-YOUR_TAVILY_KEY
SERPER_API_KEY=YOUR_SERPER_KEY

# Stripe Billing
STRIPE_SECRET_KEY=sk_live_YOUR_STRIPE_SECRET
STRIPE_WEBHOOK_SECRET=whsec_YOUR_WEBHOOK_SECRET
STRIPE_PRICE_PRO=price_PRO_PLAN_ID
STRIPE_PRICE_ENTERPRISE=price_ENTERPRISE_PLAN_ID

# Email (Resend recommended)
RESEND_API_KEY=re_YOUR_RESEND_KEY
EMAIL_FROM=noreply@herkulio.com
EMAIL_ADMIN=admin@herkulio.com

# Telegram Bot (optional)
TELEGRAM_BOT_TOKEN=YOUR_BOT_TOKEN_FROM_BOTFATHER

# App Config
APP_ENV=production
APP_URL=https://herkulio.com
API_URL=https://api.herkulio.com
DEBUG=false

# Investigation Limits
MAX_INVESTIGATION_DURATION=300
DEFAULT_SEARCH_DEPTH=standard
CACHE_TTL_DAYS=7
MAX_INVESTIGATIONS_PER_HOUR=10

# Feature Flags
ENABLE_BILLING=true
ENABLE_WEBHOOKS=true
ENABLE_API_KEYS=true
ENABLE_SIGNUPS=true

# Backup (S3-compatible)
BACKUP_S3_BUCKET=herkulio-backups
BACKUP_AWS_KEY=YOUR_AWS_KEY
BACKUP_AWS_SECRET=YOUR_AWS_SECRET
BACKUP_AWS_REGION=us-east-1

# Monitoring (optional)
SENTRY_DSN=https://YOUR_SENTRY_DSN
LOG_LEVEL=INFO
