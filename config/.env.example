# Herkulio API Environment Variables

# Database
DATABASE_URL=postgresql://herkulio:herkulio_password@postgres:5432/herkulio
REDIS_URL=redis://redis:6379/0

# Security
SECRET_KEY=generate_a_strong_random_key_here
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# OpenRouter (for AI synthesis)
OPENROUTER_API_KEY=your_openrouter_api_key
DEFAULT_MODEL=google/gemini-2.5-flash

# Search APIs
TAVILY_API_KEY=your_tavily_key
SERPER_API_KEY=your_serper_key

# Stripe (for billing)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_ENTERPRISE=price_...

# Email (SendGrid/Resend)
RESEND_API_KEY=re_...
EMAIL_FROM=noreply@herkulio.com

# App Config
APP_ENV=development
APP_URL=http://localhost:3000
API_URL=http://localhost:8000

# Investigation Settings
MAX_INVESTIGATION_DURATION=300
DEFAULT_SEARCH_DEPTH=standard
CACHE_TTL_DAYS=7

# Feature Flags
ENABLE_BILLING=false
ENABLE_WEBHOOKS=true
ENABLE_API_KEYS=true
